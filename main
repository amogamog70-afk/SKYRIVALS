local ItemChamsGroup = Tabs.Visual:AddLeftGroupbox('Item Chams')

-- item chams
local itemChamsEnabled, itemChamsColor, itemChamsTransp, itemChamsRainbow = false, Color3.fromRGB(255,0,255), 0, false
local itemChamsConn, itemChamsOrigData = nil, {}

local function getHeldItems(char)
    local parts = {}
    for _, obj in ipairs(char:GetChildren()) do
        if obj:IsA("Tool") then
            for _, part in ipairs(obj:GetDescendants()) do
                if part:IsA("BasePart") then table.insert(parts, part) end
            end
        end
    end
    return parts
end

local function itemChamsApply()
    local char = LocalPlayer.Character; if not char then return end
    local parts = getHeldItems(char)
    for part in pairs(itemChamsOrigData) do if not part or not part.Parent then itemChamsOrigData[part]=nil end end
    for _, part in ipairs(parts) do
        if not itemChamsOrigData[part] then
            itemChamsOrigData[part] = { Material=part.Material, Color=part.Color, Transparency=part.Transparency }
        end
        part.Material = Enum.Material.Neon
        part.Transparency = itemChamsTransp
        part.Color = itemChamsRainbow and Color3.fromHSV(tick()%5/5,1,1) or itemChamsColor
    end
end

local function itemChamsRestore()
    for part, data in pairs(itemChamsOrigData) do
        if part and part.Parent then part.Material=data.Material; part.Color=data.Color; part.Transparency=data.Transparency end
    end
    itemChamsOrigData = {}
end

local function startItemChams()
    if itemChamsConn then itemChamsConn:Disconnect() end
    itemChamsConn = RunService.Heartbeat:Connect(function() if itemChamsEnabled then itemChamsApply() end end)
end

local function stopItemChams()
    if itemChamsConn then itemChamsConn:Disconnect(); itemChamsConn=nil end
    itemChamsRestore()
end

ItemChamsGroup:AddToggle('ItemChamsEnable', { Text='Item Chams', Default=false, Callback=function(v) itemChamsEnabled=v if v then startItemChams() else stopItemChams() end end })
ItemChamsGroup:AddToggle('ItemChamsRainbow', { Text='Rainbow', Default=false, Callback=function(v) itemChamsRainbow=v end })
ItemChamsGroup:AddSlider('ItemChamsTransp', { Text='Transparency', Default=0, Min=0, Max=100, Rounding=0, Callback=function(v) itemChamsTransp=v/100 if itemChamsEnabled then itemChamsApply() end end })
ItemChamsGroup:AddLabel('Item Color'):AddColorPicker('ItemChamsColor', { Default=Color3.fromRGB(255,0,255), Callback=function(v) itemChamsColor=v if itemChamsEnabled then itemChamsApply() end end })

local drawings = {}
local BAR_W    = 4
local BAR_GAP  = 3

local function newDraw(t, props)
    local d = Drawing.new(t)
    for k, v in pairs(props) do d[k] = v end
    return d
end

local function getOrCreate(player)
    if drawings[player] then return drawings[player] end
    drawings[player] = {
        box    = newDraw('Square', { Visible=false, Color=Color3.new(1,1,1), Thickness=1, Filled=false }),
        bar_bg = newDraw('Square', { Visible=false, Color=Color3.new(0,0,0), Thickness=1, Filled=true }),
        bar    = newDraw('Square', { Visible=false, Color=Color3.new(0,1,0), Thickness=1, Filled=true }),
        name   = newDraw('Text',   { Visible=false, Color=Color3.new(1,1,1), Size=13, Center=true, Outline=true, OutlineColor=Color3.new(0,0,0) }),
        dist   = newDraw('Text',   { Visible=false, Color=Color3.new(0.8,0.8,0.8), Size=11, Center=true, Outline=true, OutlineColor=Color3.new(0,0,0) }),
    }
    return drawings[player]
end

local function removeDrawings(player)
    if drawings[player] then
        for _, d in pairs(drawings[player]) do d:Remove() end
        drawings[player] = nil
    end
end

local function clearAllESP() for p in pairs(drawings) do removeDrawings(p) end end

local espEnabled = false
local espBox     = false
local espHP      = false
local espName    = false
local espDist    = false
local espThick   = 1
local espMaxDist = 500

ESPGroup:AddToggle('ESPEnabled', { Text='ESP Enable',    Default=false, Callback=function(v) espEnabled=v end })
ESPGroup:AddToggle('BoxESP',     { Text='Box',           Default=false, Callback=function(v) espBox=v     end })
ESPGroup:AddToggle('HealthBar',  { Text='HP Bar',        Default=false, Callback=function(v) espHP=v      end })
ESPGroup:AddToggle('NameESP',    { Text='Name',          Default=false, Callback=function(v) espName=v    end })
ESPGroup:AddToggle('DistESP',    { Text='Distance',      Default=false, Callback=function(v) espDist=v    end })
ESPGroup:AddSlider('ESPThick',   { Text='Box Thickness', Default=1,   Min=1,  Max=5,    Rounding=1, Callback=function(v) espThick=v    end })
ESPGroup:AddSlider('MaxDist',    { Text='Max Distance',  Default=500, Min=50, Max=2000, Rounding=0, Callback=function(v) espMaxDist=v  end })

RunService.RenderStepped:Connect(function()
    if not espEnabled then
        for p in pairs(drawings) do removeDrawings(p) end
        return
    end
    local activePlayers = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        activePlayers[player] = true
        local d    = getOrCreate(player)
        local char = player.Character
        local hum  = char and char:FindFirstChild('Humanoid')
        local root = char and char:FindFirstChild('HumanoidRootPart')
        local head = char and char:FindFirstChild('Head')
        if not (char and hum and root and head) or hum.Health <= 0 then
            for _, v in pairs(d) do v.Visible = false end
            continue
        end
        local dist = (Camera.CFrame.Position - root.Position).Magnitude
        if dist > espMaxDist then
            for _, v in pairs(d) do v.Visible = false end
            continue
        end
        local rootPos, rootVis = Camera:WorldToViewportPoint(root.Position)
        local headPos          = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.7, 0))
        local feetPos          = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.0, 0))
        if not rootVis then
            for _, v in pairs(d) do v.Visible = false end
            continue
        end
        local height = math.max(math.abs(headPos.Y - feetPos.Y), 1)
        local width  = height * 0.55
        local cx     = rootPos.X
        local topY   = math.min(headPos.Y, feetPos.Y)
        local x      = cx - width / 2
        local y      = topY
        d.box.Visible   = espBox
        d.box.Size      = Vector2.new(width, height)
        d.box.Position  = Vector2.new(x, y)
        d.box.Thickness = espThick
        local hp    = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
        local barX  = x - BAR_W - BAR_GAP
        local fillH = height * hp
        d.bar_bg.Visible  = espHP
        d.bar_bg.Size     = Vector2.new(BAR_W, height)
        d.bar_bg.Position = Vector2.new(barX, y)
        d.bar.Visible  = espHP
        d.bar.Color    = Color3.new(1 - hp, hp, 0)
        d.bar.Size     = Vector2.new(BAR_W, fillH)
        d.bar.Position = Vector2.new(barX, y + height - fillH)
        d.name.Visible  = espName
        d.name.Text     = player.DisplayName
        d.name.Position = Vector2.new(cx, y - 15)
        d.dist.Visible  = espDist
        d.dist.Text     = math.floor(dist) .. ' st'
        d.dist.Position = Vector2.new(cx, y + height + 2)
    end
    for player in pairs(drawings) do
        if not activePlayers[player] then removeDrawings(player) end
    end
end)

Players.PlayerRemoving:Connect(removeDrawings)

