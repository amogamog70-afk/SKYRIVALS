local trailEnabled, trailIsGradient, trailLifetime, trailTranspStart, trailRainbow = false, false, 0.5, 0, false
local trailColorStatic, trailGrad1, trailGrad2, trailObj, trailConn = Color3.fromRGB(0,255,255), Color3.fromRGB(0,86,255), Color3.fromRGB(255,0,0), nil, nil
local function removeTrail(char)
    char = char or LocalPlayer.Character; if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then if hrp:FindFirstChild("DhTrailA0") then hrp.DhTrailA0:Destroy() end if hrp:FindFirstChild("DhTrailA1") then hrp.DhTrailA1:Destroy() end end
    if char:FindFirstChild("DhTrail") then char.DhTrail:Destroy() end trailObj=nil
end
local function addTrail(char)
    removeTrail(char)
    local hrp=char:WaitForChild("HumanoidRootPart",5); if not hrp then return end
    local a0=Instance.new("Attachment",hrp) a0.Name="DhTrailA0" a0.Position=Vector3.new(0,2,0)
    local a1=Instance.new("Attachment",hrp) a1.Name="DhTrailA1" a1.Position=Vector3.new(0,-2,0)
    local trail=Instance.new("Trail") trail.Name="DhTrail" trail.Attachment0=a0 trail.Attachment1=a1 trail.Lifetime=trailLifetime trail.LightEmission=0.2 trail.Enabled=true
    trail.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,trailTranspStart),NumberSequenceKeypoint.new(1,1)})
    trail.Color=trailIsGradient and ColorSequence.new(trailGrad1,trailGrad2) or ColorSequence.new(trailColorStatic)
    trail.Parent=char trailObj=trail
end
local function updateTrail()
    if not trailObj or not trailObj.Parent then return end
    trailObj.Lifetime=trailLifetime
    trailObj.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,trailTranspStart),NumberSequenceKeypoint.new(1,1)})
    if trailIsGradient then trailObj.Color=ColorSequence.new(trailGrad1,trailGrad2)
    elseif trailRainbow then trailObj.Color=ColorSequence.new(Color3.fromHSV(tick()%5/5,1,1))
    else trailObj.Color=ColorSequence.new(trailColorStatic) end
end
TrailGroup:AddToggle('TrailEnable',{Text='Enable Trail',Default=false,Callback=function(v) trailEnabled=v if v then if LocalPlayer.Character then addTrail(LocalPlayer.Character) end if trailConn then trailConn:Disconnect() end trailConn=RunService.Heartbeat:Connect(updateTrail) else removeTrail() if trailConn then trailConn:Disconnect(); trailConn=nil end end end})
TrailGroup:AddToggle('TrailGradient',{Text='Gradient Mode',Default=false,Callback=function(v) trailIsGradient=v if trailEnabled and LocalPlayer.Character then addTrail(LocalPlayer.Character) end end})
TrailGroup:AddToggle('TrailRainbow',{Text='Rainbow (Simple)',Default=false,Callback=function(v) trailRainbow=v end})
