        speedEnabled=false
        if Toggles and Toggles.SpeedHack then task.defer(function() Toggles.SpeedHack:SetValue(false) end) end
        return
    end
    speedEnabled=v
    if v then startSpeed() else stopSpeed() end
end})
MovGroup:AddSlider('SpeedValue',{Text='Speed Multiplier',Default=2,Min=1,Max=5,Rounding=1,Callback=function(v) speedValue=math.clamp(v,1,5) end})
MovGroup:AddToggle('SpeedBypass',{Text='Speed Bypass',Default=false,Callback=function(v) speedBypass=v end})

