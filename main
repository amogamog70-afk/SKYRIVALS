    ['Blue Night']={SkyboxBk='rbxassetid://12064107',SkyboxDn='rbxassetid://12064152',SkyboxFt='rbxassetid://12064121',SkyboxLf='rbxassetid://12063984',SkyboxRt='rbxassetid://12064115',SkyboxUp='rbxassetid://12064131'},
}
local skyboxNames={} for n in pairs(skyboxAssets) do table.insert(skyboxNames,n) end table.sort(skyboxNames)
local skyboxEnabled, currentSky, currentSkyboxName = false, nil, skyboxNames[1]
local originalSky = Lighting:FindFirstChildOfClass("Sky")
local originalSkyData = originalSky and {SkyboxBk=originalSky.SkyboxBk,SkyboxFt=originalSky.SkyboxFt,SkyboxLf=originalSky.SkyboxLf,SkyboxRt=originalSky.SkyboxRt,SkyboxUp=originalSky.SkyboxUp,SkyboxDn=originalSky.SkyboxDn} or nil
local function applySkybox(name)
    local a=skyboxAssets[name]; if not a then return end
    if currentSky and currentSky.Parent then currentSky:Destroy() end
    for _,ex in ipairs(Lighting:GetChildren()) do if ex:IsA("Sky") then ex:Destroy() end end
    local sky=Instance.new("Sky")
    sky.SkyboxBk=a.SkyboxBk; sky.SkyboxFt=a.SkyboxFt; sky.SkyboxLf=a.SkyboxLf; sky.SkyboxRt=a.SkyboxRt; sky.SkyboxUp=a.SkyboxUp; sky.SkyboxDn=a.SkyboxDn
    sky.Parent=Lighting; currentSky=sky
end
local function removeSkybox()
    if currentSky and currentSky.Parent then currentSky:Destroy() end currentSky=nil
    if originalSkyData then local s=Instance.new("Sky") s.SkyboxBk=originalSkyData.SkyboxBk; s.SkyboxFt=originalSkyData.SkyboxFt; s.SkyboxLf=originalSkyData.SkyboxLf; s.SkyboxRt=originalSkyData.SkyboxRt; s.SkyboxUp=originalSkyData.SkyboxUp; s.SkyboxDn=originalSkyData.SkyboxDn; s.Parent=Lighting end
end
WorldGroup:AddToggle('SkyboxEnable',{Text='Custom Skybox',Default=false,Callback=function(v) skyboxEnabled=v if v then applySkybox(currentSkyboxName) else removeSkybox() end end})
WorldGroup:AddDropdown('SkyboxSelect',{Text='Skybox',Values=skyboxNames,Default=skyboxNames[1],Callback=function(v) currentSkyboxName=v if skyboxEnabled then applySkybox(v) end end})

-- MOVEMENT (patched)
local MovGroup  = Tabs.Movement:AddLeftGroupbox('Speed')
local FlyGroup  = Tabs.Movement:AddLeftGroupbox('Fly')
local SpinGroup = Tabs.Movement:AddRightGroupbox('Spinbot')

local flyEnabled, flySpeed, flyConn, flyKeysDown = false, 15, nil, {}
UIS.InputBegan:Connect(function(input, processed) if processed then return end flyKeysDown[input.KeyCode]=true end)
UIS.InputEnded:Connect(function(input) flyKeysDown[input.KeyCode]=false end)

local speedEnabled, speedValue, speedConn, speedBypass, speedSeed = false, 2, nil, false, 0

local function speedNudgeBypass(hrp)
    speedSeed += 1
    local tiny = ((speedSeed % 2 == 0) and 1 or -1) * 0.001
    hrp.CFrame = hrp.CFrame + Vector3.new(tiny, 0, -tiny)
end

local function stopSpeed() if speedConn then speedConn:Disconnect(); speedConn=nil end end
local function startSpeed()
    if flyEnabled then
        speedEnabled=false
        if Toggles and Toggles.SpeedHack then Toggles.SpeedHack:SetValue(false) end
        return
    end
    stopSpeed()
    speedConn = RunService.Heartbeat:Connect(function()
        if not speedEnabled or flyEnabled then return end
        local char=LocalPlayer.Character
        local hrp=char and char:FindFirstChild("HumanoidRootPart")
        local hum=char and char:FindFirstChildOfClass("Humanoid")
        if hrp and hum and hum.MoveDirection.Magnitude > 0 then
            local amount = math.clamp(speedValue, 1, 5) / 10
            hrp.CFrame = hrp.CFrame + (hum.MoveDirection.Unit * amount)
            if speedBypass then
                speedNudgeBypass(hrp)
                hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, math.clamp(hrp.AssemblyLinearVelocity.Y, -2, 2), hrp.AssemblyLinearVelocity.Z)
            end
        end
    end)
end

local function stopFly() if flyConn then flyConn:Disconnect(); flyConn=nil end end
local function startFly()
    stopFly()
    flyConn = RunService.Heartbeat:Connect(function(dt)
        if not flyEnabled then return end
        local char=LocalPlayer.Character
        local hrp=char and char:FindFirstChild("HumanoidRootPart")
        local hum=char and char:FindFirstChildOfClass("Humanoid")
        if not (hrp and hum) then return end
        local moveDir=Vector3.new(0,0,0)
        if flyKeysDown[Enum.KeyCode.W] then moveDir += Camera.CFrame.LookVector end
        if flyKeysDown[Enum.KeyCode.S] then moveDir -= Camera.CFrame.LookVector end
        if flyKeysDown[Enum.KeyCode.A] then moveDir -= Camera.CFrame.RightVector end
        if flyKeysDown[Enum.KeyCode.D] then moveDir += Camera.CFrame.RightVector end
        if flyKeysDown[Enum.KeyCode.Space] then moveDir += Vector3.new(0,1,0) end
        if flyKeysDown[Enum.KeyCode.LeftShift] then moveDir -= Vector3.new(0,1,0) end
        if moveDir.Magnitude > 0 then hrp.CFrame = hrp.CFrame + (moveDir.Unit * flySpeed * dt) end
        hrp.Velocity = Vector3.new(0,-5,0)
        hum:ChangeState(Enum.HumanoidStateType.Falling)
    end)
end

FlyGroup:AddToggle('FlyEnable',{Text='Fly (X to toggle)',Default=false,Callback=function(v)
    flyEnabled=v
    if v and speedEnabled then
        speedEnabled=false
        stopSpeed()
        if Toggles and Toggles.SpeedHack then Toggles.SpeedHack:SetValue(false) end
    end
    if v then startFly() else stopFly() end
end})
FlyGroup:AddSlider('FlySpeed',{Text='Fly Speed',Default=15,Min=1,Max=30,Rounding=1,Callback=function(v) flySpeed=math.clamp(v,1,30) end})

UIS.InputBegan:Connect(function(input,gp)
    if not gp and input.KeyCode == Enum.KeyCode.X then
        flyEnabled = not flyEnabled
        if flyEnabled and speedEnabled then
            speedEnabled=false
            stopSpeed()
            if Toggles and Toggles.SpeedHack then Toggles.SpeedHack:SetValue(false) end
        end
        if flyEnabled then startFly() else stopFly() end
        if Toggles and Toggles.FlyEnable then Toggles.FlyEnable:SetValue(flyEnabled) end
    end
end)

