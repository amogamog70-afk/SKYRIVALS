-- FLY-KILL
local fkEnabled     = false
local fkSpeed       = 30
local fkMaxDist     = 650
local fkOrbitEnabled = false
local fkOrbitRadius  = 4      -- расстояние вокруг цели при orbit
local fkOrbitSpeed   = 15     -- градусов в секунду
local fkOrbitAngle   = 0      -- текущий угол (накапливается)
local fkTarget      = nil
local fkAtt0, fkAlignPos, fkAlignOri

local function fkSetupPhysics()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp  = char:WaitForChild("HumanoidRootPart")
    if fkAtt0     then fkAtt0:Destroy()     end
    if fkAlignPos then fkAlignPos:Destroy() end
    if fkAlignOri then fkAlignOri:Destroy() end

    fkAtt0 = Instance.new("Attachment", hrp)
    fkAtt0.Name = "FlyKillAtt0"

    fkAlignPos = Instance.new("AlignPosition", hrp)
    fkAlignPos.Attachment0   = fkAtt0
    fkAlignPos.Mode          = Enum.PositionAlignmentMode.OneAttachment
    fkAlignPos.MaxForce      = 100000
    fkAlignPos.MaxVelocity   = fkSpeed
    fkAlignPos.Responsiveness = 50
    fkAlignPos.Enabled       = false

    fkAlignOri = Instance.new("AlignOrientation", hrp)
    fkAlignOri.Attachment0   = fkAtt0
    fkAlignOri.Mode          = Enum.OrientationAlignmentMode.OneAttachment
    fkAlignOri.MaxTorque     = 100000
    fkAlignOri.Responsiveness = 50
    fkAlignOri.Enabled       = false
end

local function fkSetNoClip(state)
    local char = LocalPlayer.Character
    if not char then return end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = not state
        end
    end
end

local function fkIsSafe(p)
    if not p or not p.Character then return false end
    local tHrp = p.Character:FindFirstChild("HumanoidRootPart")
    local hum  = p.Character:FindFirstChild("Humanoid")
    return tHrp and hum and hum.Health > 0
end

local function fkGetTarget()
    local closest, dist = nil, fkMaxDist
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and fkIsSafe(p) then
            local d = (char.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then
                dist    = d
                closest = p
            end
        end
    end
    return closest
end

local function fkStop()
    fkEnabled = false
    fkTarget  = nil
    if fkAlignPos then fkAlignPos.Enabled = false end
    if fkAlignOri then fkAlignOri.Enabled = false end
    fkSetNoClip(false)
end

RunService.Heartbeat:Connect(function(dt)
    if not fkEnabled then return end
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if not fkTarget or not fkIsSafe(fkTarget) then
        fkTarget    = fkGetTarget()
        fkOrbitAngle = 0
    end

    if fkTarget and fkTarget.Character then
        local tHrp = fkTarget.Character:FindFirstChild("HumanoidRootPart")
        if tHrp then
            local dist = (hrp.Position - tHrp.Position).Magnitude
            if dist > fkMaxDist then fkTarget = nil return end
            if not fkAlignPos or fkAlignPos.Parent ~= hrp then fkSetupPhysics() end

            fkAlignPos.MaxVelocity = fkSpeed
            fkAlignPos.Enabled     = true
            fkAlignOri.Enabled     = true
            fkSetNoClip(true)

            local goalPos
            if fkOrbitEnabled then
                -- Orbit: крутимся вокруг цели, fkOrbitSpeed = оборотов в минуту (1-30)
                local radsPerSec = (fkOrbitSpeed / 60) * (2 * math.pi)
                fkOrbitAngle = fkOrbitAngle + radsPerSec * dt
                local offsetX = math.cos(fkOrbitAngle) * fkOrbitRadius
                local offsetZ = math.sin(fkOrbitAngle) * fkOrbitRadius
                goalPos = tHrp.Position + Vector3.new(offsetX, 1.5, offsetZ)
            else
                -- Обычный режим: позади цели
                local offsetZ = dist <= 8 and 4 or 10
                local offsetY = 2
                goalPos = (tHrp.CFrame * CFrame.new(0, offsetY, offsetZ)).Position
            end

            fkAlignPos.Position = goalPos
            fkAlignOri.CFrame   = CFrame.lookAt(hrp.Position, tHrp.Position)
            hrp.AssemblyLinearVelocity = Vector3.new(
                hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z
            )
        end
    end
end)

UIS.InputBegan:Connect(function(input, gp)
    if not gp and input.KeyCode == Enum.KeyCode.Z then
        fkEnabled = not fkEnabled
        fkTarget  = nil
        fkOrbitAngle = 0
        if fkEnabled then fkSetupPhysics() else fkStop() end
        if Toggles and Toggles.FlyKillEnable then Toggles.FlyKillEnable:SetValue(fkEnabled) end
    end
end)

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    fkAtt0 = nil; fkAlignPos = nil; fkAlignOri = nil
    if fkEnabled then fkSetupPhysics() end
end)

CombatGroup:AddToggle('FlyKillEnable',  { Text='Fly-Kill (Z to toggle)',    Default=false, Callback=function(v) fkEnabled=v fkTarget=nil fkOrbitAngle=0 if v then fkSetupPhysics() else fkStop() end end })
CombatGroup:AddToggle('FlyKillOrbit',   { Text='Orbit Mode (крутиться)',     Default=false, Callback=function(v) fkOrbitEnabled=v fkOrbitAngle=0 end })
CombatGroup:AddSlider('FlyKillOrbitR',  { Text='Orbit Radius',  Default=4,   Min=2, Max=15,  Rounding=1, Callback=function(v) fkOrbitRadius=v end })
CombatGroup:AddSlider('FlyKillOrbitSpd',{ Text='Orbit Speed',   Default=15,  Min=1, Max=30, Rounding=0, Callback=function(v) fkOrbitSpeed=v end })
CombatGroup:AddSlider('FlyKillSpeed',   { Text='Fly Speed',     Default=30,  Min=1,  Max=30,  Rounding=1, Callback=function(v) fkSpeed=v end })
CombatGroup:AddSlider('FlyKillDist',    { Text='Max Distance',  Default=650, Min=50, Max=650, Rounding=0, Callback=function(v) fkMaxDist=v end })
-- AUTO ATTACK: жмёт ЛКМ когда враг в радиусе хитбокса
local autoAttackEnabled = false
local autoAttackCPS     = 10
local autoAttackAcc     = 0

RunService.Heartbeat:Connect(function(dt)
    if not autoAttackEnabled then return end
    -- ищем ближайшего живого врага
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local nearest = math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local tHrp = p.Character:FindFirstChild("HumanoidRootPart")
            local hum  = p.Character:FindFirstChild("Humanoid")
            if tHrp and hum and hum.Health > 0 then
                local d = (hrp.Position - tHrp.Position).Magnitude
                if d < nearest then nearest = d end
            end
        end
    end
    -- атакуем только если враг в радиусе хитбокса
    local threshold = hbexSize * 0.5 + 2
    if nearest > threshold then autoAttackAcc = 0 return end
    autoAttackAcc += dt
    local period = 1 / autoAttackCPS
    if autoAttackAcc >= period then
        autoAttackAcc -= period
        pcall(function()
            VirtualUser:Button1Down(Vector2.new(0, 0), Camera.CFrame)
            task.wait()
            VirtualUser:Button1Up(Vector2.new(0, 0), Camera.CFrame)
        end)
    end
end)

CombatGroup:AddToggle('AutoAttack',    { Text='Auto Attack (в радиусе хитбокса)', Default=false, Callback=function(v) autoAttackEnabled=v autoAttackAcc=0 end })
CombatGroup:AddSlider('AutoAttackCPS', { Text='CPS', Default=10, Min=1, Max=20, Rounding=0, Callback=function(v) autoAttackCPS=v end })

-- HITBOXEX (patched max=25)
local hbexEnabled, hbexSize, hbexTransp = false, 4, 0.8
local hbexColor, hbexNoCollide = Color3.fromRGB(255,0,0), false
local hbexOrigData, hbexConn = {}, nil

local function hbexApply()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local char = p.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                if not hbexOrigData[hrp] then
                    hbexOrigData[hrp] = {
                        Size = hrp.Size, Transparency=hrp.Transparency, Color=hrp.Color,
                        CanCollide=hrp.CanCollide, CastShadow=hrp.CastShadow,
                    }
                end
                hrp.Size = Vector3.new(hbexSize, hbexSize, hbexSize)
                hrp.Transparency = hbexTransp
                hrp.Color = hbexColor
                hrp.CanCollide = not hbexNoCollide
                hrp.CastShadow = false
            end
        end
    end
end

local function hbexRestore()
    for hrp, data in pairs(hbexOrigData) do
        if hrp and hrp.Parent then
            hrp.Size=data.Size; hrp.Transparency=data.Transparency; hrp.Color=data.Color
            hrp.CanCollide=data.CanCollide; hrp.CastShadow=data.CastShadow
        end
    end
    hbexOrigData = {}
end

local function startHbex()
    if hbexConn then hbexConn:Disconnect() end
    hbexApply()
    hbexConn = RunService.Heartbeat:Connect(function() if hbexEnabled then hbexApply() end end)
    Players.PlayerAdded:Connect(function(p)
        p.CharacterAdded:Connect(function()
            task.wait(0.5)
            if hbexEnabled then hbexApply() end
        end)
    end)
    for _, p in ipairs(Players:GetPlayers()) do
        p.CharacterAdded:Connect(function()
            task.wait(0.5)
            if hbexEnabled then hbexApply() end
        end)
    end
end

local function stopHbex()
    if hbexConn then hbexConn:Disconnect(); hbexConn=nil end
    hbexRestore()
end

HitboxGroup:AddToggle('HbexEnable', { Text='Enable HitboxEx', Default=false, Callback=function(v) hbexEnabled=v if v then startHbex() else stopHbex() end end })
HitboxGroup:AddSlider('HbexSize', { Text='HRP Size', Default=4, Min=1, Max=15, Rounding=1, Callback=function(v) hbexSize=math.clamp(v,1,15) if hbexEnabled then hbexApply() end end })
HitboxGroup:AddSlider('HbexTransp', { Text='Transparency', Default=80, Min=0, Max=100, Rounding=0, Callback=function(v) hbexTransp=v/100 if hbexEnabled then hbexApply() end end })
HitboxGroup:AddLabel('HRP Color'):AddColorPicker('HbexColor', { Default=Color3.fromRGB(255,0,0), Callback=function(v) hbexColor=v if hbexEnabled then hbexApply() end end })
HitboxGroup:AddToggle('HbexNoCollide', { Text='No Collision (walk through)', Default=false, Callback=function(v) hbexNoCollide=v if hbexEnabled then hbexApply() end end })

-- VISUALS / ESP
local ESPGroup       = Tabs.Visual:AddLeftGroupbox('ESP')
