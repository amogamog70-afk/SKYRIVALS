local ffEnabled, ffColor, ffRainbow, ffOrigColors, ffConn = false, Color3.fromRGB(128,128,128), false, {}, nil
local function saveFFColors(char) ffOrigColors={} for _,p in pairs(char:GetDescendants()) do if p:IsA("BasePart") and p.Name~="DeadHubHat" then ffOrigColors[p]={Color=p.Color,Material=p.Material} end end end
local function applyFF(char) saveFFColors(char) for _,p in pairs(char:GetDescendants()) do if p:IsA("BasePart") and p.Name~="DeadHubHat" then p.Color=ffColor; p.Material=Enum.Material.ForceField end end end
local function removeFF() for part,data in pairs(ffOrigColors) do if part and part.Parent then part.Color=data.Color; part.Material=data.Material end end ffOrigColors={} end
local function updateFF() if not ffEnabled then return end local char=LocalPlayer.Character if not char then return end for _,p in pairs(char:GetDescendants()) do if p:IsA("BasePart") and p.Name~="DeadHubHat" and p.Material==Enum.Material.ForceField then p.Color=ffRainbow and Color3.fromHSV(tick()%5/5,1,1) or ffColor end end end
FFGroup:AddToggle('FFEnable',{Text='Enable ForceField',Default=false,Callback=function(v) ffEnabled=v local char=LocalPlayer.Character if char then if v then applyFF(char) if ffConn then ffConn:Disconnect() end ffConn=RunService.Heartbeat:Connect(updateFF) else if ffConn then ffConn:Disconnect(); ffConn=nil end removeFF() end end end})
