local hatEnabled, hatColor, hatTransp, hatRainbow, hatPart, hatConn = false, Color3.fromRGB(0,255,255), 0.3, false, nil, nil
local function removeHat() if hatPart and hatPart.Parent then hatPart:Destroy() end hatPart=nil end
local function addHat(char)
    removeHat(); task.wait(0.1)
    local head = char:WaitForChild("Head",5); if not head then return end
    local hat=Instance.new("Part") hat.Name="DeadHubHat" hat.CanCollide=false hat.Transparency=hatTransp hat.Color=hatColor hat.Material=Enum.Material.Neon
    local mesh=Instance.new("SpecialMesh",hat) mesh.MeshId="rbxassetid://1033714" mesh.Scale=Vector3.new(2.4,1.6,2.4)
    local weld=Instance.new("WeldConstraint",hat) weld.Part0=head weld.Part1=hat
    hat.CFrame=head.CFrame * CFrame.new(0,1.1,0); hat.Parent=char; hatPart=hat
end
local function updateHat() if hatPart and hatPart.Parent then hatPart.Transparency=hatTransp hatPart.Color=hatRainbow and Color3.fromHSV(tick()%5/5,1,1) or hatColor end end
HatGroup:AddToggle('HatEnable',{Text='Enable Chinese Hat',Default=false,Callback=function(v) hatEnabled=v if v then if LocalPlayer.Character then addHat(LocalPlayer.Character) end if hatConn then hatConn:Disconnect() end hatConn=RunService.Heartbeat:Connect(updateHat) else removeHat() if hatConn then hatConn:Disconnect(); hatConn=nil end end end})
