-- robust re-apply on respawn/transfer
local function reapplyAll(char)
    task.wait(0.8)
    if fkEnabled then fkSetupPhysics() end
    if hbexEnabled then hbexApply() end
    if itemChamsEnabled then startItemChams() end
    if hatEnabled then addHat(char) end
    if trailEnabled then addTrail(char) end
    if ffEnabled then applyFF(char) end
    if skinTrailEnabled then addSkinTrail(char) end
    if flyEnabled then startFly() end
    if speedEnabled and not flyEnabled then startSpeed() end
    if spinEnabled then startSpin() end
    clearAllESP()
end
LocalPlayer.CharacterAdded:Connect(reapplyAll)

