local skinTrailEnabled, skinTrailColor, skinTrailLife = false, Color3.fromRGB(255,0,0), 0.5
local function removeSkinTrail(char)
    char=char or LocalPlayer.Character; if not char then return end
    local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    for _,v in pairs(char:GetChildren()) do
        if v:IsA("BasePart") and v~=hrp then
            if v:FindFirstChild("DhSkinTrail") then v.DhSkinTrail:Destroy() end
            if v:FindFirstChild("DhSkinPtr1") then v.DhSkinPtr1:Destroy() end
        end
    end
    for _,obj in pairs(hrp:GetChildren()) do if obj.Name=="DhSkinPtr2" then obj:Destroy() end end
end
local function addSkinTrail(char)
    removeSkinTrail(char)
    local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    for _,v in pairs(char:GetChildren()) do
        if v:IsA("BasePart") and v~=hrp then
            local trail=Instance.new("Trail") trail.Name="DhSkinTrail" trail.Texture="rbxassetid://1390780157"
            local p1=Instance.new("Attachment",v) p1.Name="DhSkinPtr1"
            local p2=Instance.new("Attachment",hrp) p2.Name="DhSkinPtr2"
            trail.Attachment0=p1; trail.Attachment1=p2
            trail.Color=ColorSequence.new(skinTrailColor,skinTrailColor)
            trail.Lifetime=skinTrailLife
            trail.Parent=v
        end
    end
end
local function updateSkinTrail() local char=LocalPlayer.Character if not char then return end for _,v in pairs(char:GetDescendants()) do if v:IsA("Trail") and v.Name=="DhSkinTrail" then v.Color=ColorSequence.new(skinTrailColor,skinTrailColor); v.Lifetime=skinTrailLife end end end
SkinTrGroup:AddToggle('SkinTrailEnable',{Text='Enable Skin Trail',Default=false,Callback=function(v) skinTrailEnabled=v local char=LocalPlayer.Character if v and char then addSkinTrail(char) elseif char then removeSkinTrail(char) end end})
SkinTrGroup:AddLabel('Trail Color'):AddColorPicker('SkinTrailColor',{Default=Color3.fromRGB(255,0,0),Callback=function(v) skinTrailColor=v; updateSkinTrail() end})
SkinTrGroup:AddSlider('SkinTrailLife',{Text='Lifetime',Default=5,Min=1,Max=30,Rounding=0,Callback=function(v) skinTrailLife=v/10; updateSkinTrail() end})

