    ['Default']={SkyboxBk='rbxasset://sky/moon_bk.jpg',SkyboxDn='rbxasset://sky/moon_dn.jpg',SkyboxFt='rbxasset://sky/moon_ft.jpg',SkyboxLf='rbxasset://sky/moon_lf.jpg',SkyboxRt='rbxasset://sky/moon_rt.jpg',SkyboxUp='rbxasset://sky/moon_up.jpg'},
