local fullbrightConn=nil; local optimizeActive=false
local function applyFullbright() Lighting.Brightness=2; Lighting.ClockTime=12; Lighting.GlobalShadows=false; Lighting.Ambient=Color3.fromRGB(255,255,255); Lighting.OutdoorAmbient=Color3.fromRGB(255,255,255) end
local function OptimizeCharacter(char,owner)
    if owner==LocalPlayer then return end
    for _,v in ipairs(char:GetDescendants()) do
        if v:IsA("Shirt") or v:IsA("Pants") or v:IsA("ShirtGraphic") then v:Destroy()
        elseif v:IsA("Accessory") then v:Destroy()
        elseif v:IsA("Decal") and v.Name=="face" then v.Transparency=1 end
    end
end
MiscGroup:AddToggle('FPSBoost',{Text='FPS Boost',Default=false,Callback=function(v)
    FpsText.Visible=v
    if v then
        for _,obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("ParticleEmitter") or obj:IsA("Trail") then obj.Enabled=false
            elseif obj:IsA("BlurEffect") or obj:IsA("SunRaysEffect") or obj:IsA("BloomEffect") or obj:IsA("ColorCorrectionEffect") then obj.Enabled=false
            elseif obj:IsA("BasePart") then obj.CastShadow=false end
        end
        if Terrain then pcall(function() Terrain.WaterWaveSize=0; Terrain.WaterWaveSpeed=0; Terrain.WaterReflectance=0; Terrain.WaterTransparency=1 end) end
        pcall(function() settings().Rendering.QualityLevel=Enum.QualityLevel.Level01 end)
    else
        pcall(function() settings().Rendering.QualityLevel=Enum.QualityLevel.Automatic end)
    end
end})
MiscGroup:AddToggle('Fullbright',{Text='Fullbright',Default=false,Callback=function(v) if v then applyFullbright(); if fullbrightConn then fullbrightConn:Disconnect() end fullbrightConn=Lighting.Changed:Connect(applyFullbright) else if fullbrightConn then fullbrightConn:Disconnect(); fullbrightConn=nil end end end})
MiscGroup:AddToggle('OptimizeChars',{Text='Optimize Other Players',Default=false,Callback=function(v)
    optimizeActive=v
    if v then
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr.Character then OptimizeCharacter(plr.Character,plr) end
            plr.CharacterAdded:Connect(function(char) task.wait(0.8); if optimizeActive then OptimizeCharacter(char,plr) end end)
        end
        Players.PlayerAdded:Connect(function(plr) plr.CharacterAdded:Connect(function(char) task.wait(0.8); if optimizeActive then OptimizeCharacter(char,plr) end end) end)
    end
end})

