local origFogEnd, origFogStart = Lighting.FogEnd, Lighting.FogStart
local origAmbient, origOutdoor, origFogColor = Lighting.Ambient, Lighting.OutdoorAmbient, Lighting.FogColor
local fogConn, cloudsObj, origCloudsDensity, origCloudsCover = nil, nil, nil, nil
local function findClouds() local c=Terrain and Terrain:FindFirstChildOfClass("Clouds") if not c then c=workspace:FindFirstChildOfClass("Clouds") end return c end
WorldGroup:AddToggle('NoFog',{Text='No Fog',Default=false,Callback=function(v)
    if v then
        Lighting.FogEnd=1e6; Lighting.FogStart=1e6
        if fogConn then fogConn:Disconnect() end
        fogConn=Lighting:GetPropertyChangedSignal("FogEnd"):Connect(function() Lighting.FogEnd=1e6; Lighting.FogStart=1e6 end)
        cloudsObj=findClouds(); if cloudsObj then origCloudsDensity=cloudsObj.Density; origCloudsCover=cloudsObj.Cover; cloudsObj.Density=0; cloudsObj.Cover=0 end
    else
        if fogConn then fogConn:Disconnect(); fogConn=nil end
        Lighting.FogEnd=origFogEnd; Lighting.FogStart=origFogStart
        if cloudsObj and cloudsObj.Parent then cloudsObj.Density=origCloudsDensity or 0.3; cloudsObj.Cover=origCloudsCover or 0.5 end
        cloudsObj=nil
    end
end})

local worldColorEnabled, worldColor, colorCorrection = false, Color3.fromRGB(255,255,255), nil
local function applyWorldColor(color)
    colorCorrection=Lighting:FindFirstChildOfClass("ColorCorrectionEffect")
    if not colorCorrection then colorCorrection=Instance.new("ColorCorrectionEffect",Lighting) end
    colorCorrection.TintColor=color
    Lighting.Ambient=Color3.new(color.R*0.6,color.G*0.6,color.B*0.6)
    Lighting.OutdoorAmbient=Color3.new(color.R*0.5,color.G*0.5,color.B*0.5)
    Lighting.FogColor=color
end
local function removeWorldColor()
    if colorCorrection and colorCorrection.Parent then colorCorrection.TintColor=Color3.new(1,1,1) end
    Lighting.Ambient=origAmbient; Lighting.OutdoorAmbient=origOutdoor; Lighting.FogColor=origFogColor
end
WorldGroup:AddToggle('WorldColorEnable',{Text='World Color',Default=false,Callback=function(v) worldColorEnabled=v if v then applyWorldColor(worldColor) else removeWorldColor() end end})
WorldGroup:AddLabel('World Color'):AddColorPicker('WorldColorPicker',{Default=Color3.fromRGB(255,255,255),Callback=function(v) worldColor=v if worldColorEnabled then applyWorldColor(v) end end})

